/*
 * DEPRECATED — do not treat this file as the live Chocofi layout.
 *
 * Production / GHA builds pass:
 *   -DKEYMAP_FILE=config/temper.keymap       (macOS)
 *   -DKEYMAP_FILE=config/temper_linux.keymap (Linux)
 * so Chocofi and Temper share the same keymap source (36-key geometry).
 *
 * This shield file only exists so a bare west build without KEYMAP_FILE still
 * parses; it is intentionally a minimal stub. Edit config/temper*.keymap.
 *
 * SPDX-License-Identifier: MIT
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &none &none &none &none &none   &none &none &none &none &none
                &none &none &none &none &none   &none &none &none &none &none
                &none &none &none &none &none   &none &none &none &none &none
                            &none &none &none   &none &none &none
            >;
        };
    };
};
